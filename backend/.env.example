# -----------------------------------------------------------------------------
# DATABASE_URL
# - Port must be numeric (5432 for local Postgres, or the number shown in Aiven).
#   Using the word PORT causes Prisma error P1013 (invalid port number).
# - If the password contains @ : # / % etc., URL-encode it in the connection string.
# - Aiven: Service → Overview → Connection information → copy URI, then add
#   &connection_limit=5 if you want (see backend/README.md).
# -----------------------------------------------------------------------------

# Local PostgreSQL example:
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/property_management"

# Aiven example (replace YOUR_PASSWORD, YOUR_SERVICE subdomain, and 27961 with values from your console):
DATABASE_URL="postgres://avnadmin:YOUR_PASSWORD@YOUR_SERVICE.j.aivencloud.com:27961/defaultdb?sslmode=require&connection_limit=5"

PORT=4000
JWT_SECRET=change-me-to-at-least-16-characters

# Optional: comma-separated frontend origins for CORS (default allows localhost:3000, 3007)
# FRONTEND_ORIGIN=http://localhost:3007,https://yoursite.com

# If you get TLS "bad certificate format" when connecting to Aiven from local,
# run with: NODE_TLS_REJECT_UNAUTHORIZED=0 npm run dev
# Or add Aiven's CA certificate to your system / Prisma config.
