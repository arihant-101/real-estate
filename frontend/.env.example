# API base URL (backend). Use full URL in production when frontend and backend are on different origins.
NEXT_PUBLIC_API_BASE=https://realestate-u3vr.onrender.com

# Canonical site URL (sitemap, robots, Open Graph, metadata). In dev, set to your dev origin if not port 3000 (e.g. http://localhost:3001).
NEXT_PUBLIC_SITE_URL=

# Optional: external client portal / CRM URL. When set, the portal page shows an "Open client portal" link for documents, rent, and maintenance.
NEXT_PUBLIC_PORTAL_URL=

# Optional: Google Maps Embed API key. When set, property detail pages show an embedded map; otherwise a "View on Google Maps" link is shown.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# Optional: Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Loaded only after the user allows analytical cookies.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional: Meta (Facebook) Pixel ID (numeric). Loaded only after the user allows marketing cookies.
NEXT_PUBLIC_META_PIXEL_ID=
